<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane layoutX="276.0" layoutY="23.0" prefHeight="200.0" prefWidth="376.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.andy.linearj.Screen.controllers.NetlistUnitController">
    <TableView fx:id="circuitElementTableView" focusTraversable="false" layoutY="2.0" prefHeight="146.0" prefWidth="376.0" stylesheets="@CSSStyleSheets/Netlist.css">
        <columns>
            <TableColumn fx:id="componentIDColumn" prefWidth="75.0" styleClass="\@CSSStyleSheets/Netlist.css" text="ID" />
            <TableColumn fx:id="begNodeIDColumn" prefWidth="75.0" sortable="false" styleClass="CSSStyleSheets/Netlist.css" text="Beg Node" />
            <TableColumn fx:id="endNodeIDColumn" prefWidth="75.0" sortable="false" styleClass="CSSStyleSheets/Netlist.css" text="End Node" />
            <TableColumn fx:id="componentValueColumn" prefWidth="75.0" sortable="false" styleClass="CSSStyleSheets/Netlist.css" text="Value" />
        </columns>

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER" layoutX="1.0" layoutY="150.0" prefHeight="48.0" prefWidth="376.0" spacing="75.0">
        <Button fx:id="clearNetlistBtn" defaultButton="true" disable="true" mnemonicParsing="false" prefWidth="150.0" stylesheets="@CSSStyleSheets/buttons.css" text="Clear Netlist" onAction="#clearNetlist">
            <styleClass>
                <String fx:value="button_main" />
                <String fx:value="button-primary" />
            </styleClass>
        </Button>

        <Button fx:id="removeElementBtn" defaultButton="true" disable="true" mnemonicParsing="false" prefWidth="150.0" stylesheets="@CSSStyleSheets/buttons.css" text="Remove Element" onAction="#removeNetlistElement">
            <styleClass>
                <String fx:value="button_main" />
                <String fx:value="button-primary" />
            </styleClass>
        </Button>
    </HBox>
</AnchorPane>
